{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Redixis operational dashboard.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Auth Redis Uptime",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "max(redixis_redis_up{role=\"auth\"})", "legendFormat": "auth redis", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "max": 1,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "min"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 2,
      "title": "Tenant Redis Uptime",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "max(redixis_redis_up{role=\"tenant\"})", "legendFormat": "tenant redis", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "max": 1,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "min"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 3,
      "title": "Request Rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 6},
      "targets": [{"expr": "sum(rate(redixis_http_requests_total[$__rate_interval])) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value"}
    },
    {
      "id": 4,
      "title": "HTTP Error Rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 6},
      "targets": [{"expr": "100 * ((sum(rate(redixis_http_requests_total{status=~\"4..|5..\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(redixis_http_requests_total[$__rate_interval])), 0.001))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 5,
      "title": "HTTP p95",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 6},
      "targets": [{"expr": "1000 * histogram_quantile(0.95, sum(rate(redixis_http_request_duration_seconds_bucket[$__rate_interval])) by (le))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}}, "overrides": []},
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 6,
      "title": "Active Requests",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 6},
      "targets": [{"expr": "sum(redixis_http_requests_in_flight{job=\"redixis\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "red", "value": 100}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {"id": 7, "title": "HTTP", "type": "row", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10}, "panels": []},
    {
      "id": 8,
      "title": "HTTP Status Mix",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 11},
      "targets": [{"expr": "sum by (status) (rate(redixis_http_requests_total[$__rate_interval]))", "legendFormat": "{{status}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9,
      "title": "Route Load",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 11},
      "targets": [{"expr": "sum by (route) (rate(redixis_http_requests_total[$__rate_interval]))", "legendFormat": "{{route}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"displayMode": "lcd", "orientation": "vertical", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "valueMode": "color"}
    },
    {"id": 11, "title": "Redis", "type": "row", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19}, "panels": []},
    {
      "id": 12,
      "title": "Redis Operations",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{"expr": "sum by (operation, purpose, status) (rate(redixis_redis_operations_total[$__rate_interval]))", "legendFormat": "{{operation}} {{purpose}} {{status}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "mean"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 13,
      "title": "Redis Latency By Purpose",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "1000 * histogram_quantile(0.95, sum by (le, purpose) (rate(redixis_redis_operation_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{purpose}} p95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 2, "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 14,
      "title": "Redis Load By Purpose",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 28},
      "targets": [{"expr": "sum by (purpose) (rate(redixis_redis_operations_total[$__rate_interval]))", "legendFormat": "{{purpose}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "valueMode": "color"}
    },
    {
      "id": 15,
      "title": "Redis Errors By Operation",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 28},
      "targets": [{"expr": "sum by (operation, purpose, error) (rate(redixis_redis_errors_total[$__rate_interval]))", "legendFormat": "{{operation}} {{purpose}} {{error}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {"id": 16, "title": "Runtime", "type": "row", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35}, "panels": []},
    {
      "id": 17,
      "title": "Process CPU",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 36},
      "targets": [{"expr": "rate(process_cpu_seconds_total{job=\"redixis\"}[$__rate_interval])", "legendFormat": "redixis api cpu", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 18,
      "title": "Memory",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 36},
      "targets": [{"expr": "process_resident_memory_bytes{job=\"redixis\"}", "legendFormat": "redixis api rss", "refId": "A"}, {"expr": "go_memstats_heap_alloc_bytes{job=\"redixis\"}", "legendFormat": "redixis api heap alloc", "refId": "B"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 19,
      "title": "Goroutines",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 36},
      "targets": [{"expr": "go_goroutines{job=\"redixis\"}", "legendFormat": "redixis api goroutines", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    }
  ],
